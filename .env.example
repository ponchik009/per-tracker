POSTGRES_USER="pet_user"
POSTGRES_PASSWORD="pet_password"
POSTGRES_DB="pet_tracker"
DATABASE_URL="postgresql://pet_user:pet_password@postgres:5432/pet_tracker?schema=public"
TELEGRAM_BOT_TOKEN=""
BOT_USERNAME=""
DEFAULT_TIMEZONE="Europe/Moscow"
# Docker Compose подставляет redis://redis:6379 для контейнера bot. Локально без Docker: redis://127.0.0.1:6379
REDIS_URL="redis://localhost:6379"
# Разные префиксы для test/dev на одном Redis (см. docker-compose.dev — порт-хост можно сменить через REDIS_PORT)
REDIS_SESSION_PREFIX="pet-tracker"
